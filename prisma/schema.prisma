generator client {
  provider = "prisma-client"
  output   = "../src/core/database/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// task model
model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
